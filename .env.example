# --- Database ---
# PostgreSQL connection string (local, Docker, Supabase, Neon, Railway, etc.)
DATABASE_URL="postgresql://user:password@localhost:5432/social_app?schema=public"

# --- NextAuth ---
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-random-32-byte-secret"
NEXTAUTH_URL="http://localhost:3000"

# --- OAuth providers (optional, add if you enable them in lib/auth.ts) ---
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Image upload (optional, e.g. if using Cloudinary/UploadThing) ---
UPLOAD_API_KEY=""
UPLOAD_API_SECRET=""

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
